{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "rootDir": "src",
        "outDir": "dist",
        "strict": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "types": ["node"]
    },
    "include": ["src"],
    "exclude": [
        "**/*.test.ts",
        "src/lib/supabase/client.ts",
        "src/lib/supabase/server.ts",
        "src/lib/supabase/middleware.ts",
        "src/lib/supabase/getUserClient.ts",
        "src/lib/supabase/getUserServer.ts"
    ]
}
